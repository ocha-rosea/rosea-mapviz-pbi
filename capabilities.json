      "descriptionKey": "Role_CircleLabel_Description"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "AdminPCodeNameID": {
            "max": 1
          },
          "Latitude": {
            "max": 1
          },
          "Longitude": {
            "max": 1
          },
          "Size": {
            "max": 2
          },
          "Color": {
            "max": 1
          },
          "MapboxAccessToken": {
            "max": 1
          },
          "MaptilerApiKey": {
            "max": 1
          },
          "CircleLabel": {
            "max": 1
          }
        }
      ],
      "categorical": {
        "categories": {
          "dataReductionAlgorithm": {
            "sample": {
              "count": 30000
            }
          },
          "select": [
            {
              "for": {
                "in": "AdminPCodeNameID"
              }
            },
            {
              "for": {
                "in": "Latitude"
              }
            },
            {
              "for": {
                "in": "Longitude"
              }
            }
          ]
        },
        "values": {
          "select": [
            {
              "for": {
                "in": "Size"
              }
            },
            {
              "for": {
                "in": "Color"
              }
            },
            {
              "for": {
                "in": "Tooltips"
              }
            },
            {
              "for": {
                "in": "MapboxAccessToken"
              }
            },
            {
              "for": {
                "in": "MaptilerApiKey"
              }
            },
            {
              "for": {
                "in": "CircleLabel"
              }
            }
          ]
        }
      }
    }
